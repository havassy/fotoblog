   <dc:subject>
    <rdf:Bag>
     <rdf:li>Albánia</rdf:li>
     <rdf:li>folyó</rdf:li>
     <rdf:li>hely</rdf:li>
     <rdf:li>ország</rdf:li>
     <rdf:li>táj</rdf:li>
     <rdf:li>téma</rdf:li>
    </rdf:Bag>
   </dc:subject>
   <dc:description>
    <rdf:Alt>
     <rdf:li xml:lang="x-default">Pár napja még a Shala-folyó forrásánál, a Kék Szemnél jártunk, most viszont a Shala és a Drin összefolyásától hajóztunk fel a parkig. Földi paradicsomként harangozták be a helyet, ehhez képest több mint egy órát utaztunk egy zajos és büdös hajóval, helyben pedig még a műanyagtól is égetéssel szabadultak meg a helyiek - csalódás volt.</rdf:li>
    </rdf:Alt>
   </dc:description>
