   <dc:title>
    <rdf:Alt>
     <rdf:li xml:lang="x-default">Érkezés a Blini parkba</rdf:li>
    </rdf:Alt>
   </dc:title>
   <dc:rights>
    <rdf:Alt>
     <rdf:li xml:lang="x-default">Havassy Andras</rdf:li>
    </rdf:Alt>
