   <dc:title>
    <rdf:Alt>
     <rdf:li xml:lang="x-default">Ivo Andrić szobra Višegradon</rdf:li>
    </rdf:Alt>
   </dc:title>
   <dc:rights>
    <rdf:Alt>
     <rdf:li xml:lang="x-default">Havassy Andras</rdf:li>
