   <dc:title>
    <rdf:Alt>
     <rdf:li xml:lang="x-default">Csónakázás a Piva-tavon</rdf:li>
    </rdf:Alt>
   </dc:title>
   <dc:rights>
    <rdf:Alt>
     <rdf:li xml:lang="x-default">Havassy Andras</rdf:li>
