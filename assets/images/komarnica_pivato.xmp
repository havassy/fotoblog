   <dc:subject>
    <rdf:Bag>
     <rdf:li>Komarnica</rdf:li>
     <rdf:li>Montenegró</rdf:li>
     <rdf:li>Piva</rdf:li>
     <rdf:li>folyó</rdf:li>
     <rdf:li>hely</rdf:li>
