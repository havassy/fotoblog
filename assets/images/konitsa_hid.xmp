   <dc:title>
    <rdf:Alt>
     <rdf:li xml:lang="x-default">A Konitsa-híd árnyéka az Aooos felett</rdf:li>
    </rdf:Alt>
   </dc:title>
   <dc:rights>
    <rdf:Alt>
     <rdf:li xml:lang="x-default">Havassy Andras</rdf:li>
    </rdf:Alt>
   </dc:rights>
   <dc:subject>
    <rdf:Bag>
     <rdf:li>Aoos</rdf:li>
     <rdf:li>Görögország</rdf:li>
     <rdf:li>Konitsa</rdf:li>
     <rdf:li>folyó</rdf:li>
