   <dc:title>
    <rdf:Alt>
     <rdf:li xml:lang="x-default">Melnik és a földpiramisok</rdf:li>
    </rdf:Alt>
   </dc:title>
   <dc:rights>
    <rdf:Alt>
     <rdf:li xml:lang="x-default">Havassy Andras</rdf:li>
