   <dc:title>
    <rdf:Alt>
     <rdf:li xml:lang="x-default">Prijevor a Maglić-hegységben</rdf:li>
    </rdf:Alt>
   </dc:title>
   <dc:subject>
    <rdf:Bag>
     <rdf:li>Bosznia-Hercegovina</rdf:li>
