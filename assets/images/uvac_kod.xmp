    <rdf:Bag>
     <rdf:li>Szerbia</rdf:li>
     <rdf:li>Uvac</rdf:li>
     <rdf:li>felhő</rdf:li>
     <rdf:li>hangulat</rdf:li>
     <rdf:li>hely</rdf:li>
     <rdf:li>időjárás</rdf:li>
     <rdf:li>köd</rdf:li>
     <rdf:li>ország</rdf:li>
     <rdf:li>tájnév</rdf:li>
    </rdf:Bag>
   </dc:subject>
   <dc:description>
    <rdf:Alt>
     <rdf:li xml:lang="x-default">Na ezek azok a reggelek, amelyek a vadkempingezés varázsát adják és amikor nem lehet elhagyni a helyet, csak várni és nézni, hogy hogyan változik, alakul a táj. Még Brockeni-kísértetem is volt! Ezen a napon még át kellett érnünk Montenegróba, ráadásul egy nem könnyen megközelíthető helyre: Jelov panjba.</rdf:li>
    </rdf:Alt>
   </dc:description>
